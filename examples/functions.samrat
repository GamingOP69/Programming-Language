// Samrat Functions
func add(a: int, b: int) -> int {
    return a + b
}

func greet(name: str) {
    print("Hello, " + name + "!")
}

func power(base: int, exponent: int = 2) -> int {
    let result = 1
    let i = 0
    while i < exponent {
        result = result * base
        i = i + 1
    }
    return result
}

print("add(3, 4) = " + str(add(3, 4)))
greet("Samrat")
print("power(5) = " + str(power(5)))
print("power(2, 10) = " + str(power(2, 10)))